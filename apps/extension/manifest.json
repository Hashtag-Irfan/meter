{
  "manifest_version": 3,
  "name": "METER — AI Coding Analytics",
  "version": "0.0.1",
  "description": "Privacy-first analytics for AI coding assistants. All data stays on your device.",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open METER",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
